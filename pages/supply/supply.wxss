page {
  height: 100vh;
  overflow: hidden;
  background: #f5f5f5;
  margin: 0;
  padding: 0;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  margin: 0;
}

/* 调整搜索栏：合理加高，上下内边距均衡 */
.search-bar {
  width: 100%;
  padding: 12rpx 10rpx;
  background: #fff;
}
.search-inner {
  display: flex;
  align-items: center;
  height: 44rpx; /* 输入框高度加大 */
}
.search-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
  color: #999;
}
.search-input {
  flex: 1;
  height: 100%;
  font-size: 24rpx;
}
.search-btn {
  font-size: 24rpx;
  color: #ff2442;
  padding: 0 10rpx;
}

/* 滚动区域 */
.scroll-wrap {
  flex: 1;
  overflow-y: auto;
  width: 100%;
}

/* 列表 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  padding: 10rpx;
  padding-bottom: 220rpx;
  margin: 0;
}

.photo-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-swiper {
  width: 100%;
  aspect-ratio: 1;
  background: #eee;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.text-content {
  padding: 15rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.no-img {
  width: 100%;
  height: 320rpx;
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

.loading-tip {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部导航 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  box-shadow: 0 -2rpx 15rpx rgba(0,0,0,0.05);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.center-post-btn {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background:#F5B06A;
  color: #fff;
  margin-top: -30rpx;
}

.post-icon {
  font-size: 50rpx;
  font-weight: bold;
  line-height: 1;
}

.item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  gap: 8rpx;
}

.bottomtap {
  font-size: 38rpx;
}