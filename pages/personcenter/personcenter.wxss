/* 全局容器 */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  height: 100rpx;
  margin:20rpx 0;
}

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  background: #eee;
  cursor: pointer;
}

/* 昵称 */
.nickname {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}

/* 输入框样式 */
input {
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

/* —————————— 按钮样式（class写法，规范版）—————————— */
/* 所有按钮通用基础样式 */
.login-btn, .register-btn, .avatar-btn {
  border-radius: 10rpx !important;
  height: 80rpx !important;
  font-size: 30rpx !important;
  margin-top: 20rpx !important;
  border: none !important;
  color: #fff !important;
}

/* 登录按钮：橙色 */
.login-btn {
  background-color: #FF6700 !important;
}

/* 注册按钮：绿色 */
.register-btn {
  background-color: #07C160 !important;
}

/* 更换头像按钮：蓝色 */
.avatar-btn {
  background-color: #0088FF !important;
}