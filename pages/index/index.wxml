<!-- 下面：帖子内容 -->
<view class="content-list">
  <view class="post" wx:for="{{postList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="user">
      <!-- 修复1：头像字段改为 item.avatar -->
      <image src="{{item.avatar}}" class="avatar"></image>
      <!-- 修复2：名称字段改为 item.username -->
      <text class="name">{{item.username}}</text>
    </view>
    <view class="tyty"><span class="color-text">{{item.tietype}}</span></view>
    <view class="title">{{item.title}}</view>
    <view class="text">{{item.content}}</view>
  </view>
</view>
<view class="footer">
  <view class="item" bindtap="Home">
    <view class="bottomtap">🏠</view>
  <text>主页</text>
</view>
  <view class="item" bindtap="getcomplice">
    <view class="bottomtap">🔍</view>
  <text>服务商列表</text>
</view>
<view class="item big" bindtap="pushorder">
  <view class="bottomtap">发单</view>
</view>

<view class="item" bindtap="personcenter">
  <view class="bottomtap">👤</view>
  <text>个人中心</text>
</view>

</view>
</view>