page {
  background: #f5f5f5;
}

/* 图标自动换行 */
.top-icons {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  padding: 25rpx;
  gap: 20rpx;
}

.icon-item {

  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
  margin-bottom: 20rpx;
}

.circle {
  width: 60rpx;
  height: 60rpx;
  background:  #FF6700;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.icon-item text {
  font-size: 24rpx;
  color: #333;
}

/* 帖子内容 */
.content-list {
  padding: 20rpx;
}

.post {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.user {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.name {
  font-size: 28rpx;
}
/* 你原有的样式 完全不动 */
.tyty{
  padding: 10rpx 20rpx;
  color:#FF6700;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  /* 🔥 核心修改：center → flex-end（右对齐） */
  justify-content: flex-end;
}
/* 文字样式完全不变 */
.tyty .color-text{
  color: #fff !important;
  background:#FF6700;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-weight: bold;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}
.windowsshow
{
  width:100%;
}
.footer
{
  position:fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 110rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content:space-around ;
  box-shadow: 0-2rpx 15rpx rgba(0,0,0,0.1);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}
.item
{
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size:24rpx;
  color: #666;
  gap: 8rpx;
}
.bottomtap
{
  font-size: 38rpx;
}
.item.big
{
width: 120rpx;
height: 60rpx;
background:#F5B06A;
color: white;
border-radius: 35rpx;
font-size: bold;
font-weight: bold;
box-shadow: 0 4rpx 10rpx rgba(255, 103, 0, 0.3);
}

.page {
padding-bottom: 130rpx !important;
}